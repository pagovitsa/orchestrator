#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  orch-preview static <port> [directory]
  orch-preview start <port> -- <command> [args...]
  orch-preview stop <port>
  orch-preview status

Examples:
  orch-preview static 8000 .
  orch-preview start 5173 -- npm run dev -- --host 0.0.0.0 --port 5173
EOF
}

project_dir="${ORCH_PROJECT_ROOT:-$PWD}"
state_dir="$project_dir/.orchestration/previews"
host="${ORCH_DEV_SERVER_HOST:-0.0.0.0}"
port_ranges="${ORCH_PREVIEW_PORTS:-3000-3020,5173-5190,8000-8020,8080-8090}"
preview_bind_host="${ORCH_PREVIEW_BIND_HOST:-127.0.0.1}"
lan_host="${ORCH_LAN_HOST:-}"
tailscale_host="${ORCH_TAILSCALE_HOST:-}"
public_hosts="${ORCH_PREVIEW_PUBLIC_HOSTS:-}"
browser_host="${ORCH_BROWSER_HOST:-}"

mkdir -p "$state_dir"

is_number() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

port_allowed() {
  local port="$1"
  local item start end
  IFS=',' read -ra ranges <<<"$port_ranges"
  for item in "${ranges[@]}"; do
    item="${item//[[:space:]]/}"
    if [[ "$item" == *-* ]]; then
      start="${item%-*}"
      end="${item#*-}"
      if is_number "$start" && is_number "$end" && (( port >= start && port <= end )); then
        return 0
      fi
    elif is_number "$item" && (( port == item )); then
      return 0
    fi
  done
  return 1
}

pid_file() {
  printf '%s/%s.pid' "$state_dir" "$1"
}

log_file() {
  printf '%s/%s.log' "$state_dir" "$1"
}

pid_alive() {
  local pid="${1:-}"
  is_number "$pid" && kill -0 "$pid" 2>/dev/null
}

health_url() {
  printf 'http://127.0.0.1:%s/' "$1"
}

detect_tailscale_host() {
  local detected=""
  if command -v tailscale >/dev/null 2>&1; then
    detected="$(tailscale ip -4 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$detected" ]] && command -v ip >/dev/null 2>&1; then
    detected="$(ip -4 addr show tailscale0 2>/dev/null | awk '/inet / { sub(/\\/.*$/, "", $2); print $2; exit }' || true)"
  fi
  if [[ -z "$detected" ]] && command -v hostname >/dev/null 2>&1; then
    detected="$(hostname -I 2>/dev/null | tr ' ' '\n' | awk '/^100\\./ { print; exit }' || true)"
  fi
  printf '%s' "$detected"
}

is_loopback_bind() {
  [[ "$preview_bind_host" == "127.0.0.1" || "$preview_bind_host" == "localhost" || "$preview_bind_host" == "::1" ]]
}

is_loopback_host() {
  local value="$1"
  [[ "$value" == "127.0.0.1" || "$value" == "localhost" || "$value" == "::1" || "$value" == "[::1]" ]]
}

is_tailscale_host() {
  local value="$1"
  [[ "$value" =~ ^100\. || "$value" =~ \.ts\.net$ ]]
}

format_host() {
  local value="$1"
  if [[ "$value" == *:* && "$value" != \[*\] ]]; then
    printf '[%s]' "$value"
  else
    printf '%s' "$value"
  fi
}

preview_url_for_host() {
  local value="${1%/}"
  local port="$2"
  if [[ "$value" =~ ^https?:// ]]; then
    if [[ "$value" =~ :[0-9]+$ ]]; then
      printf '%s/\n' "$value"
    else
      printf '%s:%s/\n' "$value" "$port"
    fi
  else
    printf 'http://%s:%s/\n' "$(format_host "$value")" "$port"
  fi
}

print_urls() {
  local port="$1"
  local configured host detected label printed=0
  printf 'Local: http://127.0.0.1:%s/\n' "$port"
  configured="$public_hosts"
  if [[ -z "$configured" && -n "$browser_host" ]] && ! is_loopback_host "$browser_host"; then configured="$browser_host"; fi
  if [[ -z "$configured" && -n "$tailscale_host" ]]; then configured="$tailscale_host"; fi
  if [[ -z "$configured" ]]; then
    detected="$(detect_tailscale_host)"
    if [[ -n "$detected" ]]; then configured="$detected"; fi
  fi
  if [[ -n "$lan_host" ]]; then
    configured="${configured:+$configured,}$lan_host"
  fi
  if [[ -n "$configured" ]]; then
    IFS=',' read -ra hosts <<<"$configured"
    for host in "${hosts[@]}"; do
      host="${host//[[:space:]]/}"
      [[ -n "$host" ]] || continue
      label="Network"
      if is_tailscale_host "$host"; then label="Tailscale"; fi
      printf '%-9s %s' "$label:" "$(preview_url_for_host "$host" "$port")"
      printed=1
    done
  fi
  if (( printed == 0 )); then
    echo "Network: set ORCH_TAILSCALE_HOST or ORCH_LAN_HOST to print a reachable LAN/Tailscale URL."
  elif is_loopback_bind; then
    echo "Note: Docker preview ports are bound to $preview_bind_host; set ORCH_PREVIEW_BIND_HOST=0.0.0.0 for LAN/Tailscale devices."
  fi
}

validate_port() {
  local port="${1:-}"
  if ! is_number "$port"; then
    echo "Port must be a number." >&2
    exit 2
  fi
  if ! port_allowed "$port"; then
    echo "Port $port is not in ORCH_PREVIEW_PORTS ($port_ranges)." >&2
    exit 2
  fi
}

stop_port() {
  local port="$1"
  validate_port "$port"
  local pf pid
  pf="$(pid_file "$port")"
  if [[ ! -f "$pf" ]]; then
    echo "No recorded preview on port $port."
    return 0
  fi
  pid="$(cat "$pf" 2>/dev/null || true)"
  if ! pid_alive "$pid"; then
    rm -f "$pf"
    echo "Preview on port $port was not running."
    return 0
  fi
  kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
  for _ in $(seq 1 20); do
    if ! pid_alive "$pid"; then
      rm -f "$pf"
      echo "Stopped preview on port $port."
      return 0
    fi
    sleep 0.2
  done
  kill -KILL "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  rm -f "$pf"
  echo "Force-stopped preview on port $port."
}

start_process() {
  local port="$1"
  shift
  validate_port "$port"
  if (( $# == 0 )); then
    echo "Missing command." >&2
    exit 2
  fi

  local pf lf pid
  pf="$(pid_file "$port")"
  lf="$(log_file "$port")"
  if [[ -f "$pf" ]]; then
    pid="$(cat "$pf" 2>/dev/null || true)"
    if pid_alive "$pid"; then
      echo "Preview already running on port $port (pid $pid)."
      print_urls "$port"
      echo "Log: $lf"
      exit 0
    fi
    rm -f "$pf"
  fi

  (
    cd "$project_dir"
    export HOST="$host"
    export BIND_HOST="$host"
    export VITE_HOST="$host"
    export PORT="$port"
    if command -v setsid >/dev/null 2>&1; then
      nohup setsid "$@" >"$lf" 2>&1 < /dev/null &
    else
      nohup "$@" >"$lf" 2>&1 < /dev/null &
    fi
    echo "$!" > "$pf"
  )

  pid="$(cat "$pf")"
  for _ in $(seq 1 30); do
    if ! pid_alive "$pid"; then
      echo "Preview process exited early on port $port." >&2
      tail -80 "$lf" >&2 || true
      rm -f "$pf"
      exit 1
    fi
    if curl -fsS --max-time 1 "$(health_url "$port")" >/dev/null 2>&1; then
      echo "Preview started on port $port (pid $pid)."
      print_urls "$port"
      echo "Log: $lf"
      exit 0
    fi
    sleep 0.5
  done

  echo "Preview process is running on port $port (pid $pid), but health check did not pass yet."
  print_urls "$port"
  echo "Log: $lf"
}

status_all() {
  local found=0 pf port pid lf
  for pf in "$state_dir"/*.pid; do
    [[ -e "$pf" ]] || continue
    found=1
    port="$(basename "$pf" .pid)"
    pid="$(cat "$pf" 2>/dev/null || true)"
    lf="$(log_file "$port")"
    if pid_alive "$pid"; then
      printf 'running port=%s pid=%s log=%s\n' "$port" "$pid" "$lf"
      print_urls "$port"
    else
      printf 'stale port=%s pid=%s\n' "$port" "${pid:-unknown}"
    fi
  done
  if (( found == 0 )); then
    echo "No previews recorded."
  fi
}

cmd="${1:-}"
case "$cmd" in
  static)
    port="${2:-8000}"
    directory="${3:-.}"
    start_process "$port" python3 -m http.server "$port" --bind "$host" --directory "$directory"
    ;;
  start)
    port="${2:-}"
    shift 2 || true
    if [[ "${1:-}" == "--" ]]; then shift; fi
    start_process "$port" "$@"
    ;;
  stop)
    stop_port "${2:-}"
    ;;
  status)
    status_all
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
