{
  "name": "orchestrator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "build:prompts": "node src/scripts/generate-prompts.js",
    "lint": "npm run check",
    "check": "find src test public -name '*.js' -print0 | xargs -0 -n1 node --check",
    "smoke": "node src/scripts/smoke-report.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  }
}
