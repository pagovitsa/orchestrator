# Copy to .env if you want compose to load it automatically.
# Leave empty to use the current user's $HOME/orch-projects.
ORCH_HOST_PROJECTS=

# Required only for the DeepSeek supervisor/peer route.
DEEPSEEK_API_KEY=

# Optional API keys. Set these to authenticate the CLIs via an API key instead of the browser
# ChatGPT/Google OAuth login. OAuth refresh tokens rotate, so signing into ChatGPT/Google in your
# browser with the same account can invalidate the CLI's stored token (401 token_invalidated). An
# API key avoids that. Note: API keys bill against the API, separate from a ChatGPT/Gemini plan.
OPENAI_API_KEY=
CODEX_ACCESS_TOKEN=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Auth (HTTP Basic, .htaccess-style: the browser shows a login prompt). Leave the password empty for
# loopback-only use; then the server accepts requests only from loopback / ORCH_ALLOWED_HOSTS Hosts
# (this also blocks DNS-rebinding). A password is REQUIRED before exposing the server: it REFUSES TO
# START when ORCH_BIND_HOST is non-loopback or network mode is 'host' and no password is set.
# Note: preview ports are never auth-protected.
ORCH_AUTH_USER=orchestrator
ORCH_AUTH_PASSWORD=
# Extra Host header values to accept when no password is set (comma-separated, e.g. my-box.lan).
ORCH_ALLOWED_HOSTS=

# Shared MCP tool servers exposed to the CLI supervisors (claude/codex/gemini).
# Default: serena (semantic code) + context7 (live docs) + memory (local durable facts).
# Add "playwright" to opt in to browser automation (heavier; only behind a token / loopback
# for SSRF safety).
ORCH_ENABLED_TOOLS=serena,context7,memory

# Run `git init` + .gitignore when a new project folder is created.
ORCH_GIT_INIT_PROJECTS=1

# UI and agent behavior.
ORCH_DEFAULT_SUPERVISOR=claude
ORCH_ALLOW_WRITE=1
ORCH_ALLOW_WORKSPACE_ROOT=0
# Per-run timeout in ms (3h default). Set 0 to disable auto-timeout for very long multi-round runs;
# you can always stop a run manually from the UI.
ORCH_TIMEOUT_MS=10800000
# Autopilot follow-up runs stop after this much silence; warning is sent before stop.
ORCH_AUTOPILOT_IDLE_TIMEOUT_MS=900000
ORCH_AUTOPILOT_IDLE_WARNING_MS=60000
# Autopilot decision retry for transient DeepSeek/network failures. Attempts includes the first try.
ORCH_AUTOPILOT_RETRY_ATTEMPTS=3
ORCH_AUTOPILOT_RETRY_BACKOFF_MS=2000
# Sidebar Autopilot activity entries per project; set 0 to hide the feed.
ORCH_AUTOPILOT_FEED_LIMIT=2
# Hidden backend usage probes. Default 300000ms = 5 minutes; set 0 to disable.
ORCH_USAGE_POLL_INTERVAL_MS=300000
# Optional lifetime spend warning across models that report dollar cost. 0 disables it.
ORCH_BUDGET_WARNING_USD=0
ORCH_UPLOAD_MAX_BYTES=26214400
# Off by default: pin CLI versions in the image. Set to 1 to update to @latest on boot.
ORCH_AUTO_UPDATE_CLIS=0
ORCH_CLI_PACKAGE_SPECS=@anthropic-ai/claude-code@latest @openai/codex@latest @google/gemini-cli@latest
ORCH_CLI_UPDATE_TIMEOUT_SECONDS=120
ORCH_NETWORK_MODE=bridge
ORCH_LISTEN_HOST=::
# Host interface the published ports bind to. Loopback by default; set 0.0.0.0 for LAN
# access ONLY together with ORCH_AUTH_PASSWORD.
ORCH_BIND_HOST=127.0.0.1
ORCH_BIND_HOST_IPV6=::1
# Preview/dev-server ports stay loopback even when the UI is exposed; they are NOT auth-protected.
# For LAN/Tailscale devices, set ORCH_PREVIEW_BIND_HOST=0.0.0.0 and one of the host names below.
ORCH_PREVIEW_BIND_HOST=127.0.0.1
ORCH_TAILSCALE_HOST=
ORCH_LAN_HOST=
# Optional comma-separated explicit preview hosts; overrides auto-detected Tailscale/LAN labels.
ORCH_PREVIEW_PUBLIC_HOSTS=
ORCH_UI_PORT=8787

# Preview servers launched inside project folders must bind to 0.0.0.0.
# The port ranges below are also published in docker-compose.yml.
ORCH_DEV_SERVER_HOST=0.0.0.0
ORCH_PREVIEW_PORTS=3000-3020,5173-5190,8000-8020,8080-8090

# Optional CLI model overrides.
CLAUDE_MODEL=
CODEX_MODEL=
GEMINI_MODEL=
