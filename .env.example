# Copy to .env if you want compose to load it automatically.
# Leave empty to use the current user's $HOME/orch-projects.
ORCH_HOST_PROJECTS=

# Required only for the DeepSeek supervisor/peer route.
DEEPSEEK_API_KEY=

# Optional API keys. Set these to authenticate the CLIs via an API key instead of the browser
# ChatGPT/Google OAuth login. OAuth refresh tokens rotate, so signing into ChatGPT/Google in your
# browser with the same account can invalidate the CLI's stored token (401 token_invalidated). An
# API key avoids that. Note: API keys bill against the API, separate from a ChatGPT/Gemini plan.
OPENAI_API_KEY=
CODEX_ACCESS_TOKEN=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# No HTTP basic auth. The Orchestrator is meant to live inside a Tailscale tailnet (or on
# loopback); the tailnet ACL is the authentication boundary. Leave the bind host on loopback
# unless you have network-layer protection. Preview ports are never auth-protected either.
ORCH_ALLOWED_HOSTS=

# Shared MCP tool servers exposed to the supervisors.
# Default: serena (semantic code) + context7 (live docs) + memory (local durable facts)
# + playwright (browser automation). Keep browser automation only behind a token / loopback
# for SSRF safety.
ORCH_ENABLED_TOOLS=serena,context7,memory,playwright,github
# Docker image default: use Debian Chromium instead of Playwright's managed browser download.
ORCH_PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium
ORCH_PLAYWRIGHT_HEADLESS=1
ORCH_PLAYWRIGHT_NO_SANDBOX=1

# Run `git init` + .gitignore when a new project folder is created.
ORCH_GIT_INIT_PROJECTS=1

# UI and agent behavior.
ORCH_DEFAULT_SUPERVISOR=claude
ORCH_ALLOW_WRITE=1
ORCH_ALLOW_WORKSPACE_ROOT=0
# Per-run timeout in ms (3h default). Set 0 to disable auto-timeout for very long multi-round runs;
# you can always stop a run manually from the UI.
ORCH_TIMEOUT_MS=10800000
# Autopilot follow-up runs stop after this much silence; warning is sent before stop.
ORCH_AUTOPILOT_IDLE_TIMEOUT_MS=900000
ORCH_AUTOPILOT_IDLE_WARNING_MS=60000
# Legacy: the Autopilot next-step decision is now deterministic (no model call), so this timeout no
# longer fires. Kept for compatibility; defaults to the idle timeout.
ORCH_AUTOPILOT_DECISION_TIMEOUT_MS=900000
# Legacy: decision retry/backoff is unused now that the decision is deterministic and makes no network
# call. Kept for compatibility. Attempts includes the first try.
ORCH_AUTOPILOT_RETRY_ATTEMPTS=3
ORCH_AUTOPILOT_RETRY_BACKOFF_MS=2000
# Sidebar Autopilot activity entries per project; set 0 to hide the feed.
ORCH_AUTOPILOT_FEED_LIMIT=2
# Server-side Autopilot scheduler interval. Keeps Autopilot moving even with no browser tab open.
ORCH_AUTOPILOT_SERVER_LOOP_MS=5000
# Hidden backend usage probes. Default 300000ms = 5 minutes; set 0 to disable.
ORCH_USAGE_POLL_INTERVAL_MS=300000
# Optional lifetime spend warning across models that report dollar cost. 0 disables it.
ORCH_BUDGET_WARNING_USD=0
ORCH_UPLOAD_MAX_BYTES=26214400
# Max text attachment characters inlined into the supervisor prompt across one message.
ORCH_UPLOAD_INLINE_CHARS=60000
# On by default: refresh Claude/Codex/Gemini CLI packages on container boot. Set to 0 to keep
# only the versions baked into the image, or pin exact versions below.
ORCH_AUTO_UPDATE_CLIS=1
ORCH_CLI_PACKAGE_SPECS=@anthropic-ai/claude-code@latest @openai/codex@latest @google/gemini-cli@latest
ORCH_CLI_UPDATE_TIMEOUT_SECONDS=120
ORCH_NETWORK_MODE=bridge
# Host Docker access for supervisors. The image includes Docker CLI + Compose; compose mounts this
# host socket so Claude/Codex/Gemini can run `docker` inside project folders.
ORCH_DOCKER_SOCKET=/var/run/docker.sock
ORCH_DOCKER_HOST=unix:///var/run/docker.sock
ORCH_LISTEN_HOST=::
# Host interface the published ports bind to. Loopback by default; set 0.0.0.0 only when the host
# already protects access (Tailscale tailnet, firewall, etc) - there is no built-in password.
ORCH_BIND_HOST=127.0.0.1
ORCH_BIND_HOST_IPV6=::1
# Preview/dev-server ports stay loopback even when the UI is exposed; they are NOT auth-protected.
# For LAN devices, set ORCH_PREVIEW_BIND_HOST=0.0.0.0 and one of the host names below.
ORCH_PREVIEW_BIND_HOST=127.0.0.1
# Optional Tailscale sidecar. This keeps Tailscale state inside Docker instead of using the host.
# You can set these here before boot, or save them from the Orch UI Tailscale wizard.
ORCH_TAILSCALE_AUTHKEY=
ORCH_TAILSCALE_HOSTNAME=orch-ui
ORCH_TAILSCALE_EXTRA_ARGS=--accept-dns=false
ORCH_TAILSCALE_AUTH_ONCE=true
ORCH_TAILSCALE_SERVE=1
ORCH_TAILSCALE_SERVE_RESET=1
ORCH_TAILSCALE_UI_HTTPS_PORT=443
# Set this to your MagicDNS name, e.g. https://orch-ui.your-tailnet.ts.net.
ORCH_TAILSCALE_HTTPS_HOST=
ORCH_TAILSCALE_HOST=
ORCH_LAN_HOST=
# Optional comma-separated explicit preview hosts; overrides auto-detected Tailscale/LAN labels.
ORCH_PREVIEW_PUBLIC_HOSTS=
ORCH_UI_PORT=8787

# Preview servers launched inside project folders must bind to 0.0.0.0.
# The port ranges below are also published in docker-compose.yml.
ORCH_DEV_SERVER_HOST=0.0.0.0
ORCH_PREVIEW_PORTS=3000-3020,5173-5190,8000-8020,8080-8090

# CLI model and reasoning defaults.
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_EFFORT=max
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
GEMINI_MODEL=gemini-3-pro-preview
